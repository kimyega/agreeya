<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kopo.poly.kpaas.mapper.IChatbotMapper">

    <insert id="insertQaLog" parameterType="QaLogDTO">
        INSERT INTO qa_logs (user_id, question, answer)
        VALUES (#{userId}, #{question}, #{answer})
    </insert>

</mapper>
