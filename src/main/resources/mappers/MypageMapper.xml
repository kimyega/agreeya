<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kopo.poly.kpaas.mapper.MypageMapper">

    <!-- ⚠️ 스샷 기준 테이블/컬럼명: users(user_id, name, email, nickname, birth_date ...) -->
    <select id="selectUserProfile" resultType="map">
        SELECT
            user_id    AS userId,
            name       AS name,
            email      AS email,
            nickname   AS nickname,
            birth_date AS birthDate
        FROM users
        WHERE user_id = #{userId}
    </select>

</mapper>
